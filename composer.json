{
  "name": "wyrihaximus/react-psr-3-stdio",
  "description": "Async PSR-3 stdio logger",
  "license": "MIT",
  "authors": [
    {
      "name": "Cees-Jan Kiewiet",
      "email": "ceesjank@gmail.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "psr/log": "^3.0.2",
    "react/stream": "^1.4.0",
    "wyrihaximus/psr-3-utilities": "^2.3.0"
  },
  "require-dev": {
    "wyrihaximus/async-test-utilities": "^13.3.0",
    "wyrihaximus/makefiles": "^0.12.3"
  },
  "autoload": {
    "psr-4": {
      "WyriHaximus\\React\\PSR3\\Stdio\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WyriHaximus\\React\\Tests\\PSR3\\Stdio\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "icanhazstring/composer-unused": true,
      "infection/extension-installer": true,
      "localheinz/composer-normalize": true,
      "ocramius/package-versions": true,
      "phpstan/extension-installer": true,
      "wyrihaximus/makefiles": true,
      "wyrihaximus/test-utilities": true
    },
    "platform": {
      "php": "8.4.13"
    },
    "sort-packages": true
  },
  "extra": {
    "wyrihaximus": {
      "supported-features": {
        "windows": false
      }
    }
  },
  "scripts": {
    "post-install-cmd": [
      "make on-install-or-update || true"
    ],
    "post-update-cmd": [
      "make on-install-or-update || true"
    ]
  }
}
